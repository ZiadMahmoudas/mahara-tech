                      "pm.test(\"Registration success is true\",function(){\r",
                      "    pm.expect(jsonData.success).to.eql(true);\r",
                      "});\r",
                      "pm.test(\"Response has redirect_url\",function(){\r",
                      "pm.expect(jsonData.redirect_url).to.exist;\r",
                      "});\r",
                      "let randomEmail = `test_${Date.now()}@gmail.com`;\r",
                      "pm.environment.set(\"email\", randomEmail);"
